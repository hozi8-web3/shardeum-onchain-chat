# MongoDB Configuration
# Option 1: MongoDB Atlas (Recommended)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/shardtalk?retryWrites=true&w=majority

# Option 2: Local MongoDB with Authentication
# MONGODB_URI=mongodb://username:password@localhost:27017/shardtalk

# Option 3: Local MongoDB without Authentication (Not Recommended)
# MONGODB_URI=mongodb://localhost:27017/shardtalk

MONGODB_DB=shardtalk

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
API_KEY_SECRET=your-api-key-secret-change-this-in-production-min-32-chars

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Shardeum On-Chain Chat Environment Variables
# Copy this file to .env.local and fill in your values

# Your wallet private key for contract deployment (keep this secret!)
# IMPORTANT: Remove the 0x prefix if your private key has it
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Contract address (update this after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Shardeum RPC URL
NEXT_PUBLIC_RPC_URL=https://api-unstable.shardeum.org

# Chain ID
NEXT_PUBLIC_CHAIN_ID=8080

# Explorer URL
NEXT_PUBLIC_EXPLORER_URL=https://explorer-unstable.shardeum.org

# Environment
NODE_ENV=development
